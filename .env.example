# ============================================================
# E2E Test Framework — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# ------------------------------------------------------------------
# API Tests (tests/api/)
# ------------------------------------------------------------------

# Base URL of the API server under test
API_BASE_URL=http://localhost:80

# Credentials for auth token acquisition (POST /api/auth/login)
API_USERNAME=admin
API_PASSWORD=password

# Auth endpoint path (relative to API_BASE_URL)
API_AUTH_PATH=/api/auth/login

# HTTP request timeout in seconds
API_TIMEOUT=10

# ------------------------------------------------------------------
# UI Tests (tests/ui/) — Playwright + Saucedemo
# ------------------------------------------------------------------

# Target application URL
BASE_URL=https://www.saucedemo.com

# Browser to use: chromium | firefox | webkit
BROWSER=chromium

# Playwright-specific options
HEADLESS=true
SLOW_MO=0

# ------------------------------------------------------------------
# Mobile Tests (tests/mobile/) — Appium
# ------------------------------------------------------------------

# Appium server URL
APPIUM_SERVER_URL=http://localhost:4723

# Target platform: android | ios
MOBILE_PLATFORM=android

# Android
ANDROID_DEVICE_NAME=emulator-5554
ANDROID_APP_PATH=/path/to/your-app.apk
ANDROID_APP_PACKAGE=com.example.app
ANDROID_APP_ACTIVITY=.MainActivity

# iOS
IOS_DEVICE_NAME=iPhone 15 Simulator
IOS_PLATFORM_VERSION=17.5
IOS_APP_PATH=/path/to/your-app.app
IOS_BUNDLE_ID=com.example.app

# Default explicit wait timeout (seconds)
MOBILE_ELEMENT_TIMEOUT=10

# ------------------------------------------------------------------
# Load Tests (tests/load/) — Locust
# ------------------------------------------------------------------

# Target API host for Locust
LOCUST_HOST=http://localhost:80

# Auth credentials reused from API section above
# API_USERNAME=admin
# API_PASSWORD=password

# Locust parameterisation (used by docker-compose.yml overrides)
LOCUST_USERS=5
LOCUST_SPAWN_RATE=1
LOCUST_RUN_TIME=1m

# ------------------------------------------------------------------
# Docker Compose (docker-compose.yml)
# ------------------------------------------------------------------

# Port exposed by the api-server container on the host machine
API_SERVER_HOST_PORT=8080
# Internal port the API server listens on inside the container
API_SERVER_PORT=80

# UI tests — base URL override inside Docker
UI_BASE_URL=https://www.saucedemo.com
